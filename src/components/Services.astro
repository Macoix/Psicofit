  {
    id: 'reto-21',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M10 2.5h4" /><path d="M12 2.5V6" /><path d="M18.5 6.5l1.2-1.2" /><circle cx="12" cy="14" r="8" /><text x="12" y="14" text-anchor="middle" dominant-baseline="central" font-size="8" font-weight="700" fill="currentColor" stroke="none">21</text></svg>`,
    label: 'Reto',
    name: 'Más Firmeza + Energía',
    subtitle: '21 Días',
    description: 'Ideal para probar, empezar o recuperar el ritmo. Tono muscular, menos cansancio y hábitos sencillos con rutinas cortas.',
    highlights: ['Rutinas cortas', 'Tono muscular', 'Manejo del estrés', 'Guía nutricional sencilla'],
    featured: true,
  },
  {
    id: 'reto-60',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M10 2.5h4" /><path d="M12 2.5V6" /><path d="M18.5 6.5l1.2-1.2" /><circle cx="12" cy="14" r="8" /><text x="12" y="14" text-anchor="middle" dominant-baseline="central" font-size="8" font-weight="700" fill="currentColor" stroke="none">60</text></svg>`,
    label: 'Reto',
    name: 'Cuerpo Fuerte y Cambio Visible',
    subtitle: '60 Días',
    description: 'Para resultados físicos claros en tiempo definido. Desarrollo de masa, definición, fuerza y progresión constante.',
    highlights: ['Plan adaptado', 'Fuerza y progresión', 'Guía nutricional', 'Seguimiento y apoyo mental'],
    featured: true,
  },
  {
    id: 'reto-90',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true"><path d="M10 2.5h4" /><path d="M12 2.5V6" /><path d="M18.5 6.5l1.2-1.2" /><circle cx="12" cy="14" r="8" /><text x="12" y="14" text-anchor="middle" dominant-baseline="central" font-size="8" font-weight="700" fill="currentColor" stroke="none">90</text></svg>`,
    label: 'Reto',
    name: 'Transformación Completa',
    subtitle: '90 Días',
    description: 'Cambio físico notable, equilibrio, constancia y resultados duraderos. Contarás con apoyo psicológico deportivo para superar barreras y mantener el enfoque en tus metas.',
    highlights: ['Transformación completa', 'Guía psicológica', 'Guía nutricional', 'Resultados duraderos'],
    featured: true,
  },
  {
    id: 'mujeres',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.94 8.31C13.62 7.52 12.85 7 12 7s-1.62.52-1.94 1.31l-2.99 7.47C6.86 16.44 7.35 17 8 17h2v4h4v-4h2c.65 0 1.14-.56.92-1.22l-2.98-7.47zM12 6c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2z"/></svg>`,
    label: 'Asesoría',
    name: 'Cuerpo Femenino Fuerte',
    subtitle: 'Equilibrio Total',
    description: 'Rutina 100% personalizada, diseñada respetando tu ciclo menstrual y tus necesidades reales. Definición, tonificación y control de peso.',
    highlights: ['Ajustes según tu ciclo', 'Plan gimnasio o casa', 'Nutrición adaptada a ti', 'Seguimiento y corrección de técnica'],
    featured: false,
  },
  {
    id: 'hombres',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><circle cx="12" cy="5" r="2.6" /><path d="M8 10.5a1.5 1.5 0 0 1 1.5-1.5h5a1.5 1.5 0 0 1 1.5 1.5V22h-3v-7h-2v7H8V10.5z" /></svg>`,
    label: 'Asesoría',
    name: 'Hombre Fuerte y Sólido',
    subtitle: 'Fuerza, Masa y Energía',
    description: 'Plan diseñado para llevar tu cuerpo y tu energía al máximo nivel. Desarrollo de masa muscular, fuerza y definición con progresión constante.',
    highlights: ['Rutina adaptada a tu nivel', 'Optimización de energía', 'Guía nutricional para ganar músculo o definir', 'Seguimiento semanal'],
