---
const API_KEY = import.meta.env.YOUTUBE_API_KEY ?? process.env.YOUTUBE_API_KEY;
const CHANNEL_HANDLE = 'oscar.psicofit';
const _debug = { key: API_KEY ? `${API_KEY.slice(0,8)}...` : 'UNDEFINED' };

type VideoItem = {
  id: string;
  title: string;
  thumbnail: string;
  duration: string;
};

function parseDuration(iso: string): number {
  const m = iso.match(/PT(?:(\d+)H)?(?:(\d+)M)?(?:(\d+)S)?/);
  if (!m) return 0;
  return (parseInt(m[1] ?? '0') * 3600) + (parseInt(m[2] ?? '0') * 60) + parseInt(m[3] ?? '0');
}

function formatDuration(seconds: number): string {
  const m = Math.floor(seconds / 60);
  const s = seconds % 60;
  return `${m}:${String(s).padStart(2, '0')}`;
}

let videos: VideoItem[] = [];
let apiError = false;

if (API_KEY) {
  try {
    console.log('Estoy dentro')
    // 1. Get uploads playlist ID from handle
    const chRes = await fetch(
      `https://www.googleapis.com/youtube/v3/channels?part=contentDetails&forHandle=${CHANNEL_HANDLE}&key=${API_KEY}`
    );
    const chData = await chRes.json();
    const uploadsId: string = chData.items?.[0]?.contentDetails?.relatedPlaylists?.uploads;

    if (uploadsId) {
      // 2. Get recent video IDs
      const plRes = await fetch(
        `https://www.googleapis.com/youtube/v3/playlistItems?part=snippet&playlistId=${uploadsId}&maxResults=50&key=${API_KEY}`
      );
      const plData = await plRes.json();
      const ids: string = plData.items
        ?.map((i: any) => i.snippet.resourceId.videoId)
        .join(',');

      if (ids) {
        // 3. Get durations — filter Shorts (≤ 60s)
        const vRes = await fetch(
          `https://www.googleapis.com/youtube/v3/videos?part=contentDetails,snippet&id=${ids}&key=${API_KEY}`
        );
        const vData = await vRes.json();

        videos = (vData.items ?? [])
          .filter((v: any) => parseDuration(v.contentDetails.duration) <= 60)
          .slice(0, 9)
          .map((v: any) => {
            const secs = parseDuration(v.contentDetails.duration);
            return {
              id: v.id,
              title: v.snippet.title,
              thumbnail:
                v.snippet.thumbnails?.high?.url ??
                v.snippet.thumbnails?.medium?.url ??
                `https://img.youtube.com/vi/${v.id}/hqdefault.jpg`,
              duration: formatDuration(secs),
            };
          });
      }
    }
  } catch (e) {
    console.error('[Videos] YouTube API error:', e);
    apiError = true;
  }
}

const hasVideos = videos.length > 0;
---

<section id="videos" class="py-24 bg-zinc-950 transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="inline-block font-body text-sm font-600 tracking-widest text-amber-500 uppercase mb-3">
        Canal de YouTube
      </span>
      <h2 class="font-heading font-700 text-4xl md:text-5xl text-white uppercase mb-4">
        Mis <span class="text-amber-500">Reels</span>
      </h2>
      <p class="font-body text-lg text-zinc-400 max-w-xl mx-auto leading-relaxed">
        Contenido corto sobre entrenamiento, psicología del rendimiento y bienestar integral.
      </p>
    </div>

    <!-- DEBUG TEMPORAL — borrar después -->
    <div class="text-center mb-4">
      <code class="text-xs bg-zinc-800 text-amber-400 px-3 py-1 rounded">DEBUG: API_KEY = {_debug.key}</code>
    </div>

    {!API_KEY && (
      <div class="text-center py-16 text-zinc-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 mx-auto mb-4 text-zinc-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.069A1 1 0 0121 8.868v6.264a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
        <p class="font-body text-sm">Agregá <code class="text-amber-400 bg-zinc-900 px-2 py-0.5 rounded">YOUTUBE_API_KEY</code> en <code class="text-amber-400 bg-zinc-900 px-2 py-0.5 rounded">.env</code> para cargar los reels.</p>
      </div>
    )}

    {API_KEY && apiError && (
      <div class="text-center py-16 text-zinc-500">
        <p class="font-body text-sm">No se pudieron cargar los reels. Revisá la API key o intentá de nuevo.</p>
      </div>
    )}

    {hasVideos && (
      <!-- Portrait grid — 9:16 como Reels/Shorts -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
        {videos.map((video) => (
          <div
            class="group relative bg-zinc-900 rounded-2xl overflow-hidden cursor-pointer border border-zinc-800 hover:border-amber-500/50 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-amber-500/10"
            data-video-id={video.id}
            role="button"
            tabindex="0"
            aria-label={`Reproducir: ${video.title}`}
          >
            <!-- Portrait thumbnail 9:16 -->
            <div class="relative aspect-[9/16] bg-zinc-800 overflow-hidden">
              <img
                src={video.thumbnail}
                alt={video.title}
                class="video-thumb w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
                width="360"
                height="640"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>

              <!-- Play button -->
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-12 h-12 rounded-full bg-amber-500/90 group-hover:bg-amber-400 flex items-center justify-center shadow-lg transition-all duration-200 group-hover:scale-110">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white translate-x-0.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              </div>

              <!-- Duration -->
              <span class="absolute bottom-2 right-2 bg-black/80 text-white text-xs font-600 px-1.5 py-0.5 rounded font-mono">
                {video.duration}
              </span>

              <!-- Shorts badge -->
              <span class="absolute top-2 left-2 bg-red-600 text-white text-xs font-700 px-2 py-0.5 rounded-full">
                Short
              </span>
            </div>

            <!-- Title -->
            <div class="p-3">
              <h3 class="font-body text-xs font-600 text-zinc-200 group-hover:text-white transition-colors duration-200 leading-snug line-clamp-2">
                {video.title}
              </h3>
            </div>

            <!-- Iframe container -->
            <div class="video-player hidden absolute inset-0 bg-black z-10 rounded-2xl overflow-hidden"></div>
          </div>
        ))}
      </div>
    )}

    <div class="text-center mt-12">
      <a
        href="https://www.youtube.com/@oscar.psicofit"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 border border-zinc-700 hover:border-amber-500 text-zinc-300 hover:text-amber-400 font-600 text-sm px-8 py-3 rounded-full transition-all duration-200 cursor-pointer"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
        </svg>
        Ver canal completo
      </a>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('[data-video-id]').forEach(card => {
    const activate = () => {
      const videoId = card.dataset.videoId;
      if (!videoId) return;
      const player = card.querySelector<HTMLElement>('.video-player');
      if (!player) return;

      player.innerHTML = `
        <iframe
          src="https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0"
          class="w-full h-full"
          allow="autoplay; encrypted-media; picture-in-picture"
          allowfullscreen
          title="${card.querySelector('h3')?.textContent ?? 'Video'}"
        ></iframe>
      `;
      player.classList.remove('hidden');
    };

    card.addEventListener('click', activate);
    card.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(); }
    });
  });
</script>
