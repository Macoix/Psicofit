---
const year = new Date().getFullYear();
---

<footer class="bg-zinc-950 text-white py-10 transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-4">
    <a href="#inicio" class="font-heading font-700 text-xl tracking-wide uppercase cursor-pointer">
      Psico<span class="text-amber-500">fit</span>
    </a>
    <p class="font-body text-sm text-zinc-500">© {year} Psicofit. Todos los derechos reservados.</p>
    <div class="flex gap-6">
      <a href="#servicios" class="font-body text-sm text-zinc-500 hover:text-white transition-colors duration-200 cursor-pointer">Servicios</a>
      <a href="#videos" class="font-body text-sm text-zinc-500 hover:text-white transition-colors duration-200 cursor-pointer">Videos</a>
      <a href="#trayectoria" class="font-body text-sm text-zinc-500 hover:text-white transition-colors duration-200 cursor-pointer">Trayectoria</a>
      <a href="#contacto" class="font-body text-sm text-zinc-500 hover:text-white transition-colors duration-200 cursor-pointer">Contacto</a>
    </div>
  </div>
