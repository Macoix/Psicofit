---
---

<section id="inicio" class="relative min-h-dvh flex items-center justify-center overflow-hidden pt-16 bg-zinc-50 dark:bg-zinc-950 transition-colors duration-300">
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    <div class="absolute top-0 right-0 w-96 h-96 bg-amber-100 dark:bg-amber-900/20 rounded-full blur-3xl opacity-50 translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-zinc-200 dark:bg-zinc-800 rounded-full blur-3xl opacity-40 -translate-x-1/3 translate-y-1/3"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-12 items-center">
    <div class="text-center md:text-left">
      <span class="inline-block font-body text-sm font-600 tracking-widest text-amber-500 uppercase mb-4">
        Entrenamiento · Psicología · Alto Rendimiento
      </span>

      <h1 class="font-heading font-700 text-5xl md:text-6xl lg:text-7xl leading-tight text-zinc-900 dark:text-white uppercase mb-6">
        Cuerpo &<br />
        <span class="text-zinc-700 dark:text-zinc-300">Mente en<br /></span>
        <span class="text-amber-500">Equilibrio</span>
      </h1>

      <p class="font-body text-lg text-zinc-500 dark:text-zinc-400 leading-relaxed mb-8 max-w-md mx-auto md:mx-0">
        Programas personalizados que unen el entrenamiento físico con la psicología del rendimiento.
        Transformá tu cuerpo y tu mentalidad con el acompañamiento de Oscar.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
        <a
          href="https://wa.me/573026033283"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-green-500 hover:bg-green-600 text-white font-600 text-base px-8 py-4 rounded-full transition-all duration-200 hover:shadow-xl hover:shadow-green-200 dark:hover:shadow-green-900/30 cursor-pointer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Consultá ahora
        </a>
        <a
          href="#servicios"
          class="inline-flex items-center justify-center gap-2 border-2 border-zinc-300 dark:border-zinc-700 text-zinc-700 dark:text-zinc-300 hover:bg-zinc-100 dark:hover:bg-zinc-800 font-600 text-base px-8 py-4 rounded-full transition-all duration-200 cursor-pointer"
        >
          Ver servicios
        </a>
      </div>

      <div class="mt-10 flex items-center gap-6 justify-center md:justify-start">
        <div class="text-center">
          <p class="font-heading font-700 text-3xl text-zinc-900 dark:text-white">500+</p>
          <p class="font-body text-xs text-zinc-400 dark:text-zinc-500 uppercase tracking-wider">Clientes</p>
        </div>
        <div class="w-px h-10 bg-zinc-200 dark:bg-zinc-700"></div>
        <div class="text-center">
          <p class="font-heading font-700 text-3xl text-zinc-900 dark:text-white">4</p>
          <p class="font-body text-xs text-zinc-400 dark:text-zinc-500 uppercase tracking-wider">Programas</p>
        </div>
        <div class="w-px h-10 bg-zinc-200 dark:bg-zinc-700"></div>
        <div class="text-center">
          <p class="font-heading font-700 text-3xl text-zinc-900 dark:text-white">100%</p>
          <p class="font-body text-xs text-zinc-400 dark:text-zinc-500 uppercase tracking-wider">Personalizado</p>
        </div>
      </div>
    </div>

    <div class="flex justify-center md:justify-end">
      <div class="relative w-72 h-80 md:w-80 md:h-96">
        <div class="absolute inset-0 bg-zinc-900 dark:bg-zinc-800 rounded-3xl shadow-2xl shadow-zinc-300 dark:shadow-zinc-900 flex flex-col items-center justify-center gap-4 p-8 overflow-hidden">
          <div class="absolute top-0 left-0 right-0 h-1 bg-amber-500"></div>
          <div class="w-28 h-28 rounded-full border-4 border-amber-500/40 overflow-hidden">
            <img src="/oscar.jpg" alt="Oscar — Psicólogo y Coach" class="w-full h-full object-cover" width="112" height="112" />
          </div>
          <div class="text-center">
            <p class="font-heading font-700 text-2xl text-white uppercase tracking-wide">Oscar</p>
            <p class="font-body text-sm text-zinc-400">Psicólogo & Coach</p>
          </div>
          <div class="flex gap-3 mt-2">
            <span class="bg-amber-500/20 text-amber-400 text-xs font-600 px-3 py-1 rounded-full border border-amber-500/30">Fitness</span>
            <span class="bg-zinc-700 text-zinc-300 text-xs font-600 px-3 py-1 rounded-full">Psicología</span>
          </div>
        </div>
        <div class="absolute -bottom-4 -left-4 bg-white dark:bg-zinc-800 rounded-2xl shadow-lg shadow-zinc-200 dark:shadow-zinc-900 px-4 py-3 flex items-center gap-2 border border-zinc-100 dark:border-zinc-700">
          <div class="w-8 h-8 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <p class="font-body text-xs font-600 text-zinc-800 dark:text-zinc-200">Disponible ahora</p>
            <p class="font-body text-xs text-zinc-400">Respondemos en minutos</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 text-zinc-300 dark:text-zinc-600" aria-hidden="true">
    <p class="font-body text-xs uppercase tracking-widest">Scroll</p>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
